<view class="page">
  <scroll-view
    class="chat-box"
    scroll-y="true"
    scroll-with-animation="true"
    scroll-into-view="{{toView}}"
  >
    <view
      wx:for="{{messages}}"
      wx:key="index"
      class="msg-row {{item.role}}"
    >
      <!-- AI -->
      <block wx:if="{{item.role === 'ai'}}">
        <image class="avatar" src="/images/ai.png"></image>
        <view class="msg ai">
          {{item.content}}

          <view class="action-box" wx:if="{{item.actions && item.actions.length}}">
            <view
              wx:for="{{item.actions}}"
              wx:key="index"
              class="action-btn"
              bindtap="handleAction"
              data-type="{{item.type}}"
            >
              {{item.text}}
            </view>
          </view>
        </view>
      </block>

      <!-- 用户 -->
      <block wx:elif="{{item.role === 'user'}}">
        <view class="msg user">{{item.content}}</view>
        <image class="avatar" src="/images/user.png"></image>
      </block>
    </view>

    <view id="bottom-anchor" style="height: 1px;"></view>
  </scroll-view>

  <view class="quick-box">
    <view class="quick-title">快捷提问</view>
    <view class="quick-list">
      <view class="quick-item" bindtap="quickAsk" data-question="今天练什么比较合适？">今天练什么</view>
      <view class="quick-item" bindtap="quickAsk" data-question="减脂期间晚饭怎么吃比较好？">减脂晚饭怎么吃</view>
      <view class="quick-item" bindtap="quickAsk" data-question="练腿之后酸痛怎么办？">练腿酸痛怎么办</view>
      <view class="quick-item" bindtap="quickAsk" data-question="我现在更适合增肌还是减脂？">我适合增肌还是减脂</view>
    </view>
  </view>

  <view class="input-box">
    <input
      class="input"
      value="{{input}}"
      placeholder="问点什么，比如：今天怎么安排训练？"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="sendMessage"
    />
    <button bindtap="sendMessage">发送</button>
  </view>
</view>