.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #4f7cff, #6ea8ff);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  color: #fff;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 30rpx rgba(79, 124, 255, 0.18);
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  opacity: 0.95;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.debug-box {
  margin-top: 36rpx;
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
}

.debug-result {
  margin-top: 20rpx;
  color: #444;
  font-size: 24rpx;
  word-break: break-all;
}