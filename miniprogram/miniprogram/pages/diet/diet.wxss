.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 32rpx;
  box-sizing: border-box;
}

.header-card {
  background: linear-gradient(135deg, #4f7cff, #6ea8ff);
  border-radius: 24rpx;
  padding: 34rpx 28rpx;
  color: #fff;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(79, 124, 255, 0.18);
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.96;
}

.form-card,
.result-card,
.strategy-card,
.meal-card,
.advice-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
}

.picker {
  padding: 22rpx 20rpx;
  background: #f7f8fc;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  color: #333;
  font-size: 28rpx;
}

.input {
  background: #f7f8fc;
  border-radius: 16rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  color: #222;
}

.main-btn {
  margin-top: 10rpx;
  border-radius: 16rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.strategy-text {
  font-size: 27rpx;
  color: #444;
  line-height: 1.8;
}

.meal-section {
  margin-bottom: 24rpx;
}

.meal-section:last-child {
  margin-bottom: 0;
}

.meal-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.food-item {
  background: #f7f8fc;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 10rpx;
  font-size: 25rpx;
  color: #333;
}

.advice-item {
  background: #f7f8fc;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  line-height: 1.6;
  color: #333;
  font-size: 26rpx;
}