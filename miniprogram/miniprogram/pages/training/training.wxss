.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 32rpx;
  box-sizing: border-box;
}

.header-card {
  background: linear-gradient(135deg, #4f7cff, #6ea8ff);
  border-radius: 24rpx;
  padding: 34rpx 28rpx;
  color: #fff;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(79, 124, 255, 0.18);
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.96;
}

.form-card,
.result-card,
.extra-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
}

.picker {
  padding: 22rpx 20rpx;
  background: #f7f8fc;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  color: #333;
  font-size: 28rpx;
}

.main-btn {
  margin-top: 10rpx;
  border-radius: 16rpx;
}

.day-card {
  background: #f7f8fc;
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
}

.day-top {
  margin-bottom: 18rpx;
}

.day-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 8rpx;
}

.day-focus {
  font-size: 27rpx;
  color: #4f7cff;
  font-weight: 600;
}

.small-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 10rpx;
}

.summary-box,
.group-box,
.exercise-box,
.advice-box {
  margin-bottom: 18rpx;
}

.summary-text,
.advice-text {
  font-size: 25rpx;
  color: #555;
  line-height: 1.7;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: #e9f0ff;
  color: #3d6df2;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.exercise-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid #eef1f6;
}

.exercise-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 8rpx;
}

.exercise-target {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.exercise-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  font-size: 23rpx;
  color: #444;
}

.extra-item {
  background: #f7f8fc;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  line-height: 1.6;
  color: #333;
  font-size: 26rpx;
}